# Claude Video — optional configuration
# ----------------------------------------------------------------------
# This pack works with ZERO configuration for most public videos: captions
# cover the majority of them for free. Copy this file to `.env` ONLY if
# you want a Whisper fallback for caption-less videos (local files, TikToks,
# some Vimeos), or to override the default detail mode.
#
#   cp .env.example ~/.config/watch/.env
#
# The real config lives at ~/.config/watch/.env (mode 0600) — that's where
# lib/setup.py scaffolds it and where lib/whisper.py reads keys from, not
# this Expansion folder. This file is a reference copy only.
# Whisper keys are sensitive — never commit real values anywhere.
# ----------------------------------------------------------------------

# Groq API key (preferred Whisper backend — whisper-large-v3, cheap + fast).
# Get one at console.groq.com/keys. Only needed when a video has no captions.
GROQ_API_KEY=

# OpenAI API key (alternate Whisper backend — whisper-1, standard pricing).
# Get one at platform.openai.com/api-keys. Used only if GROQ_API_KEY is unset.
OPENAI_API_KEY=

# Default detail mode: transcript | efficient | balanced | token-burner.
# Leave blank to use the built-in default (balanced).
WATCH_DETAIL=
