# Voice & File Converter — optional configuration
# ----------------------------------------------------------------------
# This pack works with ZERO configuration. Copy this file to `.env` ONLY
# if you want to override a default. The pack carries NO credentials and
# never needs an API key — every tool runs locally on your machine.
#
#   cp .env.example .env
#
# `.env` is gitignored. None of these values are sensitive.
# ----------------------------------------------------------------------

# Speech-to-text model used for transcription.
#   base           ~142 MB   "Quicker"     — fast, clear single-speaker audio
#   small          ~466 MB   "Recommended" — default; best balance for most people
#   medium         ~1.5 GB   power-user option
#   large-v3-turbo ~1.5 GB   "Most accurate" — accents, noise, cross-talk
# fetch-models.sh must have downloaded the model you set here.
CONVERTER_WHISPER_MODEL=small

# Force a transcription language (ISO 639-1: en, de, es, fr, ...).
# Leave blank for automatic language detection.
CONVERTER_WHISPER_LANG=

# CPU threads for transcription. Blank = whisper picks a sensible default.
CONVERTER_WHISPER_THREADS=

# Scratch directory for intermediate + output files before the team files
# them into your knowledge base. Default is the pack's own cache/ folder.
# Leave blank to use the default.
CONVERTER_CACHE_DIR=

# OCR language(s) for making scanned PDFs searchable (Tesseract language
# codes). Default is 'eng'. For other languages, the matching Tesseract
# language data must be installed (macOS: brew install tesseract-lang;
# Linux: e.g. apt install tesseract-ocr-deu). Combine with '+':
#   eng        English only (default)
#   deu        German
#   eng+deu    a document with both English and German text
CONVERTER_OCR_LANG=
