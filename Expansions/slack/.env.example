# Slack bot token (xoxb-...) — required.
# Created at https://api.slack.com/apps after installing your app to the workspace.
# OAuth & Permissions -> Bot User OAuth Token.
SLACK_BOT_TOKEN=

# Slack app-level token (xapp-...) — required.
# Created at Basic Information -> App-Level Tokens with the connections:write scope.
SLACK_APP_TOKEN=

# Default channel for outbound posts when no thread context exists. Optional.
# Use the channel ID (Cxxxxxxxxxx), not the channel name. Right-click the channel in Slack -> Copy link.
SLACK_DEFAULT_CHANNEL=

# Surface OS notifications on inbound messages. Optional. Default false (opt-in).
# Set to "true" if you want a desktop notification when a Slack DM arrives and Larry isn't open.
SLACK_NOTIFY_OS=false

# Minutes of Larry-inactivity before the autoresponder fires in-thread. Optional. Default 30.
# When inbound arrives and no Larry session has been active for >= this many minutes,
# the listener posts an in-thread "Larry will reply when next active" reply.
# Set to a very large number (e.g. 999999) to effectively disable.
SLACK_AUTORESPONDER_MIN=30

# Comma-separated channel IDs the listener should ignore. Optional.
SLACK_IGNORE_CHANNELS=
