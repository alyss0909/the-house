.DS_Store
__MACOSX/
*.swp
.obsidian/workspace*
.obsidian/cache
node_modules/
*.env

# Temp / scratch
tmp/
.trash/

# Live automation state & logs — NEVER commit
**/.telegram-capture-state.json
**/*.log

# Windows junk
Thumbs.db
desktop.ini

# Editor auto-backups (Notekeeper plugin)
*.nkbak

# Python build artifacts (vault is markdown-only; scripts/ is the one exception,
# but its compiled bytecode cache should never be tracked)
__pycache__/
*.pyc
