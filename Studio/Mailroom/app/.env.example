# Copy this file to ".env" and fill in the two keys.

# From app.composio.dev  ->  Settings  ->  API Keys  ->  Generate.
# This is what lets the server actually act on your Gmail (archive/draft).
COMPOSIO_API_KEY=

# Your Anthropic API key (console.anthropic.com). Used only to write reply drafts.
ANTHROPIC_API_KEY=

# Port the dashboard runs on locally. Leave as-is unless it clashes.
PORT=4599
